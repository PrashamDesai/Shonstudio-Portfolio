PORT=5000
MONGO_URI=your_mongodb_connection
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_a_strong_password
JWT_SECRET=replace_with_a_long_random_secret
LOGIN_API=/api/shonstudio-admin-secured/login

# Environment: development | production
NODE_ENV=development

# Preferred: comma-separated allowed frontend origins
# Example (dev): CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Example (prod): CORS_ORIGINS=https://shonstudio-portfolio-frontend.onrender.com
CORS_ORIGINS=

# Backwards-compatible single-origin variables (optional)
CORS_ORIGIN=
CLIENT_URL=https://shonstudio-portfolio-frontend.onrender.com
LOCAL_CLIENT_URL=http://localhost:5173
FRONTEND_URL=https://shonstudio-portfolio-frontend.onrender.com
